<Window x:Class="UOX3SettingsManager.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About UOX3 Settings Manager"
        Height="260"
        Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"
                   Foreground="{DynamicResource ControlForegroundBrush}">UOX3 Settings Manager</TextBlock>

        <TextBlock Grid.Row="1"
                   Margin="0,0,0,8"
                   Foreground="{DynamicResource ControlForegroundBrush}">Version 1.0.0</TextBlock>

        <TextBlock Grid.Row="2"
                   Margin="0,0,0,12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ControlForegroundBrush}">
            UOX3 INI editor and launcher with optional documentation hints, undo and redo support, and theme switching.
        </TextBlock>

        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Foreground="{DynamicResource ControlForegroundBrush}">
                <Hyperlink NavigateUri="https://www.uox3.org/" RequestNavigate="Hyperlink_RequestNavigate">Visit uox3.org</Hyperlink>
            </TextBlock>

            <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource ControlForegroundBrush}">
                <Hyperlink NavigateUri="https://www.uox3.org/docs/index.html" RequestNavigate="Hyperlink_RequestNavigate">Open UOX3 documentation</Hyperlink>
            </TextBlock>
        </StackPanel>

        <Button Grid.Row="5"
                Width="90"
                Height="28"
                HorizontalAlignment="Right"
                Click="CloseButton_Click">Close</Button>
    </Grid>
</Window>